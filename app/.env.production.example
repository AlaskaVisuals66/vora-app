# =====================================================================
# Variáveis de ambiente PRODUÇÃO — Easy Panel (projeto: medser)
# Defina estas variáveis nas "Environment Variables" do serviço no EasyPanel.
# =====================================================================

APP_NAME=Vora
APP_ENV=production
APP_DEBUG=false
APP_URL=https://medser.voraadigital.com
APP_PORT=8080
TZ=America/Sao_Paulo

# Gere com: php -r "echo 'base64:' . base64_encode(random_bytes(32));"
APP_KEY=

# ---- Banco MySQL (serviço MySQL criado no mesmo projeto) ----
DB_CONNECTION=mysql
DB_HOST=medser_mysql        # nome do serviço MySQL no EasyPanel
DB_PORT=3306
DB_DATABASE=vora
DB_USERNAME=vora
DB_PASSWORD=GERAR_SENHA_FORTE

# ---- Redis (serviço Redis criado no mesmo projeto) ----
REDIS_HOST=medser_redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Filas / cache / sessão (Redis em produção) ----
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---- Broadcasting via Soketi (pusher protocol) ----
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=vora
PUSHER_APP_KEY=GERAR_NOVA_KEY_AQUI
PUSHER_APP_SECRET=GERAR_NOVO_SECRET_AQUI
PUSHER_HOST=medser_soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
SOKETI_PORT=6001

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST=medser.voraadigital.com
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---- JWT ----
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ---- Evolution API ----
EVOLUTION_API_URL=https://evo.voraadigital.com
EVOLUTION_API_KEY=
EVOLUTION_DEFAULT_INSTANCE=

# ---- n8n ----
N8N_HOST=n8n.voraadigital.com
N8N_PORT=443
N8N_BASE_URL=https://n8n.voraadigital.com
N8N_WEBHOOK_URL=https://n8n.voraadigital.com/
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=
N8N_API_TOKEN=

# ---- Logs ----
LOG_CHANNEL=stack
LOG_LEVEL=info
