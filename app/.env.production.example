# =====================================================================
# Variáveis de ambiente PRODUÇÃO — Easy Panel (projeto: whatsapp)
# Estas variáveis são definidas no painel do Easy Panel, não em arquivo.
# Este arquivo serve só de referência do que precisa estar configurado.
# =====================================================================

APP_NAME=HelpDesk
APP_ENV=production
APP_DEBUG=false
APP_URL=https://whatsapp-app.8w2toq.easypanel.host
APP_PORT=8080
TZ=America/Sao_Paulo

# Gere com: php -r "echo 'base64:' . base64_encode(random_bytes(32));"
APP_KEY=

# ---- Banco (SQLite com volume persistente) ----
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# ---- Redis (serviço Redis criado no mesmo projeto whatsapp) ----
REDIS_HOST=whatsapp_redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Filas / cache / sessão (Redis em produção) ----
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---- Broadcasting via Soketi (pusher protocol) ----
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=helpdesk
PUSHER_APP_KEY=GERAR_NOVA_KEY_AQUI
PUSHER_APP_SECRET=GERAR_NOVO_SECRET_AQUI
PUSHER_HOST=whatsapp_soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
SOKETI_PORT=6001

# Estas precisam ficar em build-time se forem injetadas no bundle Vite.
# Como já estamos buildando dentro do Dockerfile, deixe iguais ao acima
# e re-builde a imagem se mudar.
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST=whatsapp-app.8w2toq.easypanel.host
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---- JWT (gerar novos para produção) ----
# php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ---- Evolution API (já rodando em projeto-n8n) ----
EVOLUTION_API_URL=https://projeto-n8n-evolution-api.8w2toq.easypanel.host
EVOLUTION_API_KEY=y7Se2JIvspkCrmA7t38tQq8BJNsI0jWoqS3l6Q2r4WP
EVOLUTION_PORT=8080
EVOLUTION_DEFAULT_INSTANCE=helpdesk-main

# ---- n8n (já rodando em projeto-n8n) ----
N8N_HOST=projeto-n8n-n8n.8w2toq.easypanel.host
N8N_PORT=443
N8N_BASE_URL=https://projeto-n8n-n8n.8w2toq.easypanel.host
N8N_WEBHOOK_URL=https://projeto-n8n-n8n.8w2toq.easypanel.host/
N8N_ENCRYPTION_KEY=8629c8aa7e456d492f0e0b8d911ebacbc2def6f46483ae15
N8N_WEBHOOK_SECRET=7a968c11e2982d87dd436072f08e03b536f2b57831b22208
N8N_API_TOKEN=
N8N_FORWARD_URL=https://projeto-n8n-n8n.8w2toq.easypanel.host/webhook/evo-incoming

# ---- Logs ----
LOG_CHANNEL=stack
LOG_LEVEL=info
